{
  "metrics": {
    "http_reqs": { "type": "counter", "values": { "count": 1000, "rate": 100 } },
    "http_req_duration": {
      "type": "trend",
      "values": { "avg": 245.5, "min": 50, "max": 2100, "p(90)": 450, "p(95)": 680 },
      "thresholds": {
        "p(95)<1000": { "ok": true },
        "avg<500": { "ok": true }
      }
    },
    "http_req_failed": {
      "type": "rate",
      "values": { "rate": 0.02 },
      "thresholds": {
        "rate<0.05": { "ok": true }
      }
    }
  },
  "root_group": {
    "name": "Load Test",
    "checks": [
      { "name": "status is 200", "passes": 980, "fails": 20 },
      { "name": "response time < 500ms", "passes": 900, "fails": 100 }
    ],
    "groups": []
  }
}
